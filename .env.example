# ============================================================
# Curate Mind — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# ── Convex ──────────────────────────────────────────────────
# Your Convex deployment URL.
# Found in your Convex dashboard under your project settings.
# Format: https://your-project-name.convex.cloud
CONVEX_URL=

# Convex deploy key for pushing schema and function changes.
# Found in Convex dashboard → Settings → Deploy keys.
# Required for: npx convex deploy
CONVEX_DEPLOY_KEY=

# ── OpenAI ──────────────────────────────────────────────────
# Used for generating embeddings (model: text-embedding-3-small).
# Embeddings power semantic search across the knowledge base.
# Get your key at: platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Supadata ─────────────────────────────────────────────────
# Used for web scraping (articles) and YouTube transcript extraction.
# Get your key at: supadata.ai
SUPADATA_API_KEY=

# ── Jina (Legacy) ────────────────────────────────────────────
# Previously used for web scraping. Being phased out in favor
# of Supadata. Keep this if you're still migrating intake tools.
# You can leave this blank if you're starting fresh.
JINA_API_KEY=

# ── Local Path ───────────────────────────────────────────────
# Absolute path to this project folder on your local machine.
# Used by the MCP server to read and write source files.
# Example: /Users/yourname/projects/curate-mind
CURATE_MIND_PATH=
