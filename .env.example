# ============================================================
# Curate Mind, environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# Your Convex deployment URL (from the Convex dashboard).
CONVEX_URL=

# OpenAI API key, used for generating embeddings.
OPENAI_API_KEY=

# Supadata API key, used for URL scraping and YouTube
# transcripts (required for future intake tools, optional
# for v1 markdown-only ingestion).
SUPADATA_API_KEY=

# Absolute path to this repo on your machine,
# e.g. /Users/yourname/projects/curate-mind
CURATE_MIND_PATH=
