# ============================================================
# Curate Mind, environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# Your Convex deployment URL (from the Convex dashboard).
CONVEX_URL=

# OpenAI API key, used for generating embeddings.
OPENAI_API_KEY=

# Supadata API key, used for URL scraping and YouTube transcripts.
# Required when testing or using MCP fetch tools; optional if you
# only ingest markdown files manually.
SUPADATA_API_KEY=

# Absolute path to this repo on your machine,
# e.g. /Users/yourname/projects/curate-mind
CURATE_MIND_PATH=

# MCP tool surface. Defaults to "pipeline" if omitted.
# Options:
# - daily: intake, review, browsing, profile edits, and questions
# - pipeline: default curator workflow, including extraction and evidence linking
# - admin: repair and compatibility tools included
# - all: debug mode, no filtering
# CURATE_MIND_TOOLSET=pipeline

# Week-start convention for source intake folders (default: sunday).
# Folders run Sunday → Saturday by default: sources/YYYY-MM/YYYY-MM-DD_to_DD/
# Set to "monday" if you prefer Monday → Sunday weeks.
# CURATE_MIND_WEEK_START=sunday
