{
  "name": "curate-mind-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Curate Mind research curation system",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test src/lib/sourceMetadata.test.ts",
    "typecheck": "tsc --noEmit",
    "source-links:audit": "node --import tsx src/scripts/sourceLinkBackfill.ts audit",
    "source-links:apply": "node --import tsx src/scripts/sourceLinkBackfill.ts apply",
    "beta:create": "node --import tsx src/scripts/createBetaAccount.ts",
    "beta:disable": "node --import tsx src/scripts/disableBetaAccount.ts",
    "public:smoke": "node --import tsx src/scripts/smokePublicMcp.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev:http": "tsx watch src/http.ts",
    "dev": "tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "@supadata/js": "^1.4.0",
    "convex": "^1.34.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
